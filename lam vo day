    // ----------Tui sửa phần bảng này với mấy print tiếng việt phần updateTransaction() nha-------------
    
   
    public static void printHeader() {
        System.out.println("+-------+------------+--------------------------------+-----------------+");
        System.out.printf("| %-5s | %-10s | %-30s | %-15s |\n",
                "ID", "Date", "Reason", "Amount");
        System.out.println("+-------+------------+--------------------------------+-----------------+");
    }

    public static void printFooter() {
        System.out.println("+-------+------------+--------------------------------+-----------------+");
    }

    public static void printRow(int id, String date, String reason, double amount) {

        String idStr = String.valueOf(id);
        
        String amountStr = String.format("%s$", 
        (amount == (long) amount) ? 
        String.format("%d", (long) amount) : 
        String.format("%s", amount));

        List<String> lines = splitText(reason, 30);

        for (int i = 0; i < lines.size(); i++) {

            if (i == 0) {
                System.out.printf("| %5s | %-10s | %-30s | %15s |\n",
                        idStr, date, lines.get(i), amountStr);
            } else {
                System.out.printf("| %5s | %-10s | %-30s | %15s |\n",
                        "", "", lines.get(i), "");
            }
        }
    }

    public static List<String> splitText(String text, int size) {

        List<String> list = new ArrayList<>();

        for (int i = 0; i < text.length(); i += size) {
            list.add(text.substring(i, Math.min(i + size, text.length())));
        }

        return list;
    }
    
    
