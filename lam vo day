public class WalletManagement {

    private double currentMoney;
    private int nextId = 1;

    ArrayList<personalWallet> transactions = new ArrayList<>();
    Scanner sc = new Scanner(System.in);

    public void addTransaction() {

        Date inputDate = null;
        String dateStr = "";
        String reason = "";
        double amount = 0;

        // =====INPUT DATE=====
        while (true) {
            try {
                System.out.print("Enter date (YYYY-MM-dd): ");
                dateStr = sc.nextLine().trim();

                inputDate = validateDate(dateStr);

                Date todayOnly = validateDate(
                        new SimpleDateFormat("yyyy-MM-dd")
                                .format(new Date())
                );

                if (inputDate.after(todayOnly)) {
                    throw new WalletException("Date cannot be in the future!");
                }

                break;

            } catch (WalletException e) {
                System.out.println(e.getMessage());
            }
        }

        // =====INPUT REASON=====
        while (true) {
            try {
                System.out.print("Enter reason: ");
                reason = sc.nextLine().trim();

                if (reason.isEmpty()) {
                    throw new WalletException("Reason cannot be empty!");
                }

                break;

            } catch (WalletException e) {
                System.out.println(e.getMessage());
            }
        }

        // =====INPUT AMOUNT=====
        while (true) {
            try {
                System.out.print("Enter amount (positive = income, negative = expense): ");
                amount = Double.parseDouble(sc.nextLine().trim());
                break;

            } catch (NumberFormatException e) {
                System.out.println("Invalid amount format!");
            }
        }

        // =====CREATE ID=====
        int id = nextId++;
        currentMoney += amount;

        personalWallet newTransaction
                = new personalWallet(id, inputDate, reason, amount);

        transactions.add(newTransaction);

        System.out.println("\n>>> Transaction created successfully!");
        System.out.println("Transaction ID: " + id);

        // =====SHOW ALL TRANSACTIONS OF THAT DATE=====
        System.out.println("\nTransactions on " + dateStr + ":");

        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");

        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                System.out.println(
                        t.getId() + " | "
                        + sdf.format(t.getDate()) + " | "
                        + t.getReason() + " | "
                        + t.getAmount()
                );
            }
        }

        pause();
    }

    public Date validateDate(String dateStr) throws WalletException {
        try {
            SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");
            sdf.setLenient(false);
            return sdf.parse(dateStr);
        } catch (ParseException e) {
            throw new WalletException("Invalid date format! Use YYYY-MM-dd.");
        }
    }

    private void pause() {
        System.out.println("\nPress Enter to continue...");
        sc.nextLine();
    }

    public void loadData() {
        try {

            File file = new File("wallet.txt");
            if (!file.exists()) {
                return;
            }

            Scanner fileScanner = new Scanner(file);
            SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");

            while (fileScanner.hasNextLine()) {

                String line = decode(fileScanner.nextLine());

                String[] parts = line.split("\\|");

                int id = Integer.parseInt(parts[0]);
                Date date = sdf.parse(parts[1]);
                String reason = parts[2];
                double amount = Double.parseDouble(parts[3]);

                transactions.add(new personalWallet(id, date, reason, amount));
                currentMoney += amount;
                if (id >= nextId) {
                    nextId = id + 1;
                }
            }

            fileScanner.close();

        } catch (Exception e) {
            System.out.println("Error loading file!");
        }
    }

    public void updateTransaction() {

        if (transactions.isEmpty()) {
            System.out.println("No transactions found!");
            pause();
            return;
        }

        String dateStr;
        Date inputDate = null;

        while (true) {
            try {
                System.out.print("Enter the date to update (YYYY-MM-dd): ");
                dateStr = sc.nextLine().trim();
                inputDate = validateDate(dateStr);
                break;
            } catch (WalletException e) {
                System.out.println(e.getMessage());
            }
        }

        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");

        ArrayList<personalWallet> listByDate = new ArrayList<>();

        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                listByDate.add(t);
            }
        }

        if (listByDate.isEmpty()) {
            System.out.println("No income or expense found on " + dateStr);
            pause();
            return;
        }

        System.out.println("\nTransaction list on " + dateStr);

        printHeader();

        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                printRow(
                        t.getId(),
                        sdf.format(t.getDate()),
                        t.getReason(),
                        t.getAmount()
                );
            }
        }
        printFooter();

//==== ID ====
        int id;
        personalWallet selected = null;

        while (true) {

            System.out.print("Which ID do you want to update: ");
            String input = sc.nextLine().trim();

            if (input.isEmpty()) {
                System.out.println("Please enter an ID!");
                continue;
            }

            if (input.length() > 10) {
                System.out.println("ID exceeds character limit!");
                continue;
            }

            try {
                id = Integer.parseInt(input); // check if number

                for (personalWallet t : listByDate) {
                    if (t.getId() == id) {
                        selected = t;
                        break;
                    }
                }

                if (selected == null) {
                    System.out.println("ID does not exist!");
                } else {
                    break;
                }

            } catch (NumberFormatException e) {
                System.out.println("ID must be a number!");
            }
        }

// ===== REASON =====
        String newReason;

        while (true) {
            System.out.print("Enter new reason: ");
            newReason = sc.nextLine().trim();

            if (newReason.isEmpty()) {
                System.out.println("Reason cannot be empty!");
                continue;
            }
            if (newReason.length() > 60) {
                System.out.println("Reason exceeds 60 characters!");
                continue;
            }

            break;
        }

// ===== AMOUNT =====
        double newAmount = 0;
        while (true) {
            System.out.print("Enter amount: ");
            String input = sc.nextLine().trim();

            if (input.isEmpty()) {
                System.out.println("Please enter amount!");
                continue;
            }

            if (input.length() > 15) {
                System.out.println("Amount exceeds character limit!");
                continue;
            }

            try {
                newAmount = Double.parseDouble(input);
                break;
            } catch (NumberFormatException e) {
                System.out.println("Amount must be a number!");
            }
        }

        currentMoney -= selected.getAmount(); // subtract old amount
        selected.setReason(newReason);
        selected.setAmount(newAmount);
        currentMoney += newAmount; // add new amount

        System.out.println("\n>>> Update successful!");
        System.out.println("\nTransaction list after update:");

        printHeader();

        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                printRow(
                        t.getId(),
                        sdf.format(t.getDate()),
                        t.getReason(),
                        t.getAmount()
                );
            }
        }

        printFooter();
    }

    
