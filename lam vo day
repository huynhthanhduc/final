    public void saveData() {

        try {

            PrintWriter pw = new PrintWriter(new FileWriter("wallet.txt"));

            SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");

            for (personalWallet t : transactions) {

                String line
                        = t.getId() + "|"
                        + sdf.format(t.getDate()) + "|"
                        + t.getReason() + "|"
                        + t.getAmount();

                String encoded = encode(line);

                pw.println(encoded);
            }

            pw.close();

        } catch (IOException e) {
            System.out.println("Error saving file!");
        }
    }

    public String encode(String text) {

        String alphabet = "abcdefghijklmnopqrstuvwxyz0123456789";
        String shift = "bcdefghijklmnopqrstuvwxyz0123456789a";

        text = text.toLowerCase();

        String result = "";

        for (int i = 0; i < text.length(); i++) {

            char c = text.charAt(i);

            int index = alphabet.indexOf(c);

            if (index != -1) {
                result += shift.charAt(index);
            } else {
                result += c;
            }

        }

        return result;
    }

    public String decode(String text) {

        String alphabet = "abcdefghijklmnopqrstuvwxyz0123456789";
        String shift = "bcdefghijklmnopqrstuvwxyz0123456789a";

        String result = "";

        for (int i = 0; i < text.length(); i++) {

            char c = text.charAt(i);

            int index = shift.indexOf(c);

            if (index != -1) {
                result += alphabet.charAt(index);
            } else {
                result += c;
            }
        }

        return result;
    }

    public void statistics() {

        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");
        sdf.setLenient(false);

        Date from = null;
        Date to = null;

        try {

            System.out.print("Enter FROM date (YYYY-MM-dd): ");
            from = sdf.parse(sc.nextLine());

            System.out.print("Enter TO date (YYYY-MM-dd): ");
            to = sdf.parse(sc.nextLine());

            Date today = new Date();

            if (from.after(to)) {
                throw new WalletException("FROM must be <= TO");
            }

            if (to.after(today)) {
                throw new WalletException("TO must be <= today");
            }

        } catch (Exception e) {
            System.out.println("Invalid date!");
            pause();
            return;
        }

        double totalIncome = 0;
        double totalExpense = 0;

        System.out.println("\nTransactions from "
                + sdf.format(from) + " to " + sdf.format(to));

        printHeader();

        for (personalWallet w : transactions) {

            Date d = w.getDate();

            if (!d.before(from) && !d.after(to)) {

                printRow(
                        w.getId(),
                        sdf.format(w.getDate()),
                        w.getReason(),
                        w.getAmount()
                );

                if (w.getAmount() > 0) {
                    totalIncome += w.getAmount();
                } else {
                    totalExpense += w.getAmount();
                }
            }
        }

        printFooter();

        System.out.println("\nTotal income: " + totalIncome);
        System.out.println("Total expense: " + totalExpense);
        System.out.println("Current money: " + currentMoney);

        pause();
    }

    public void deleteTransaction() {
        String dateStr;
        Date inputDate = null;
        List<personalWallet> foundList = new ArrayList<>();
        SimpleDateFormat sdf = new SimpleDateFormat("YYYY-MM-dd");

        if (transactions.isEmpty()) {
            System.err.println("Error: Transaction list is empty!");
            pause();
            return;
        }

        //find transaction
        while (true) {
            try {
                System.out.print("Please enter the date to delete (YYYY-MM-dd): ");
                dateStr = sc.nextLine().trim();

                if (dateStr.isEmpty()) {
                    throw new WalletException("Input cannot be empty! Please try again.");
                }
                inputDate = validateDate(dateStr);
                break;
            } catch (WalletException e) {
                System.err.println(e.getMessage());
            }
        }

        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                foundList.add(t);
            }
        }

        if (foundList.isEmpty()) {
            System.out.println("No transactions found on date " + sdf.format(inputDate));
            pause();
            return;
        }

        System.out.println("Transactions for the selected date:");
        printHeader();
        for (personalWallet t : transactions) {
            if (sdf.format(t.getDate()).equals(dateStr)) {
                printRow(
                        t.getId(),
                        sdf.format(t.getDate()),
                        t.getReason(),
                        t.getAmount()
                );
            }
        }
        printFooter();

        //id
        int id;
        personalWallet target = null;

        while (true) {
            System.out.print("Select a transaction to delete by ID: ");
            String input = sc.nextLine().trim();

            if (input.isEmpty()) {
                System.err.println("Error: ID cannot be empty!");
                continue;
            }

            if (input.length() > 10) {
                System.out.println("ID exceeds character limit!");
                continue;
            }

            try {
                id = Integer.parseInt(input);
                for (personalWallet t : foundList) {
                    if (t.getId() == id) {
                        target = t;
                        break;
                    }
                }
                if (target == null) {
                    System.err.println("Error: ID does not exist!");
                } else {
                    break;
                }
            } catch (NumberFormatException e) {
                System.err.println("Error: ID must be a number!");
            }
        }

        //yes or no
        String confirm;
        do {
            System.out.print("Are you sure you want to delete this record(Yes/No): ");
            confirm = sc.nextLine();

            if (confirm.equalsIgnoreCase("Yes")) {
                transactions.remove(target);
                foundList.remove(target);                        
                System.out.println("Transaction deleted successfully!");

                System.out.println("\nUpdated list after deletion:");

                if (foundList.isEmpty()) {
                    System.out.println("All transactions for the date " + sdf.format(inputDate) + " have been deleted.");
                    break;
                } else {
                    printHeader();
                    for (personalWallet t : transactions) {
                        if (sdf.format(t.getDate()).equals(dateStr)) {
                            printRow(
                                    t.getId(),
                                    sdf.format(t.getDate()),
                                    t.getReason(),
                                    t.getAmount()
                            );
                        }
                    }
                    printFooter();
                }
            } else if (confirm.equalsIgnoreCase("No")) {
                System.out.println("Deletion canceled. Returning to MENU...");
            } else if (confirm.equalsIgnoreCase("")) {
                System.err.println("Error: Input cannot be empty!");
            } else {
                System.err.println("Error: Please enter 'Yes' or 'No'!");
                confirm = "";
            }
        } while (!(confirm.equalsIgnoreCase("No") || confirm.equalsIgnoreCase("Yes")));

        pause();
    }
